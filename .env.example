APP_BASE_URL=http://localhost:8000

# Postgres
DATABASE_URL=postgresql+asyncpg://wad_user:wad_password@localhost:5432/wad_app

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
# Use a long random secret (32+ bytes) for HS256; short values trigger PyJWT warnings.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Local LLM
LLM_MODEL_PATH=./model.gguf
LLM_MAX_TOKENS=256
LLM_N_CTX=4096
LLM_N_THREADS=4

# Redis cache-aside for GET /api/chats/{id}/messages (seconds)
CHAT_CACHE_TTL_SECONDS=120
